generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  userId       Int           @id @default(autoincrement())
  email        String        @unique
  firstName    String
  surname      String
  password     String
  createdAt    DateTime      @default(now())
  plaidAccessToken String?
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  transactionId Int      @id @default(autoincrement())
  plaidId       String?  @unique   // ← this MUST have @unique
  userId        Int
  amount        Float
  category      String
  description   String
  source        String   @default("manual") // "manual" or "plaid"
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [userId])
}

model Budget {
  budgetId     Int      @id @default(autoincrement())
  userId       Int
  category     String
  budgetValue  Float
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [userId])
}